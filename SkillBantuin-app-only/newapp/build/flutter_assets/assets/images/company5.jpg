		<style type="text/css" id="wp-custom-css">
			@import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;400;700&display=swap");

.logo-sticky > a > img {
  max-height: 50px;
}

.csbody .btn,
.csbody .btn-default,
.btn-fore,
.csbody .button,
.csbody input[type="submit"],
.csbody input[type="button"],
.csbody input#submit,
.woocommerce #respond input#submit,
.woocommerce a.button,
.woocommerce button.button,
.woocommerce input.button {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
  font-style: normal;
  background-color: rgba(51, 51, 51, 1);
  color: #ffffff;
  border-style: solid;
  border-color: #333333;
  border-width: 1px 1px 1px 1px;
  border-radius: 0;
  -webkit-border-radius: 0;
  -moz-border-radius: 0;
  -ms-border-radius: 0;
  -o-border-radius: 0;
  padding-top: 11px;
  padding-right: 41px;
  padding-bottom: 11px;
  padding-left: 41px;
  margin: 0;
  border-radius: 10px;
  background: #3fad4f 0% 0% no-repeat padding-box;
  box-shadow: 0px 7px 20px #00000029;
  border: white;
  opacity: 1;
  height: 53px;
  line-height: 2.7;
}

.csbody .btn:hover,
.csbody .btn-default:hover,
.btn-fore:hover,
.csbody .button:hover,
.csbody input[type="submit"]:hover,
.csbody input[type="button"]:hover,
.csbody input#submit:hover,
.woocommerce #respond input#submit:hover,
.woocommerce a.button:hover,
.woocommerce button.button:hover,
.woocommerce input.button:hover {
  background: #5cc36b 0% 0% no-repeat padding-box;
}

#cshero-header .main-menu-content,
#cshero-header .full-menu-background {
  background-color: transparent;
  font-family: Dosis;
  letter-spacing: 0px;
}

ul {
  padding: 0;
  margin: 0;
  list-style: inside;
}

.input-catering {
  width: 375px !important;
}

.content-medsos {
  display: flex;
  justify-content: center;
  gap: 20px;
}

.container-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
body {
  font-family: "Plus Jakarta Sans", sans-serif;
}
h3.cs-entry-title {
  color: var(--black, #222126);
  font-family: "Plus Jakarta Sans", sans-serif;
  font-size: 36px;
  font-style: normal;
  font-weight: 700;
  line-height: 127.023%;
  letter-spacing: 1px;
}
li.cs-blog-date a {
  visibility: visible;
}

li.cs-blog-date {
  visibility: hidden;
}
li.cs-blog-author {
  display: none !important;
}
ul.unliststyle {
  display: grid;
  margin-top: 30px;
}
li.cs-blog-cats {
  visibility: hidden;
}

li.cs-blog-cats a {
  visibility: visible;
  position: relative;
  left: -18px;
  padding: 6px 8px;
  justify-content: center;
  border-radius: 50px;
  background: var(--gray-light, #ebebeb);
}
.cs0blog-title {
  margin-bottom: 0px;
  margin-top: 20px;
}
li.cs-blog-date a {
  visibility: visible;
  position: relative;
  left: -50px;
  color: #828282;
  font-size: 18px;
  font-style: normal;
  font-weight: 500;
  line-height: normal;
  letter-spacing: 1px;
}
ul.cshero-info-like {
  display: none !important;
}
.blog-modern-wrap .cs-blog .cs-blog-meta .cs-blog-info {
  margin-bottom: 0px;
}
.icon-medsos {
  width: 24px;
  height: auto;
}
header.cs-blog-header {
  display: flex !important;
  flex-direction: column-reverse !important;
}
.cs-blog-meta.cs-itemBlog-meta {
  flex-direction: column-reverse;
  display: flex;
}
.comments-area {
  display: none;
}
.cs-blog-thumbnail img {
  margin-top: 100px;
  height: 480px;
  object-fit: cover;
  border-radius: 15px;
}
#cshero-header ul.cshero-dropdown > li > a,
#cshero-header .menu-pages .menu > ul > li > a,
a.shortcode-menu {
  line-height: 90px;
}
#cshero-header .cshero-header-content-widget {
  height: 90px;
}
#cshero-header .logo > a {
  min-height: 90px;
  line-height: 90px;
  margin: 0;
  padding: 0;
  width: 100px;
}

